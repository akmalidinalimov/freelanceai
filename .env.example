# ---- Database (PostgreSQL) ----
# Local dev via docker-compose (see docker-compose.yml):
DATABASE_URL="postgresql://freelanceai:freelanceai@localhost:5432/freelanceai?schema=public"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ---- Auth / Sessions (Phase 1) ----
# Generate a strong secret, e.g. `openssl rand -base64 32`
SESSION_SECRET="change-me-in-production"

# ---- Telegram (Phase 1) ----
# From @BotFather. Treat as a private key — never commit a real value.
TELEGRAM_BOT_TOKEN=""
# Public bot username (no @) — used by the client-side Login Widget.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=""

# ---- Media storage (Phase 2) — S3-compatible (e.g. Cloudflare R2) ----
S3_ENDPOINT=""
S3_REGION="auto"
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_BASE_URL=""

# ---- Payments (Phase 5) ----
# Payme
PAYME_MERCHANT_ID=""
PAYME_KEY=""
# Click
CLICK_MERCHANT_ID=""
CLICK_SERVICE_ID=""
CLICK_SECRET_KEY=""

# ---- Platform economics ----
# Commission taken by the platform, as a percentage of order value.
PLATFORM_COMMISSION_PCT="20"

# ======================================================================
# Everything below is optional for a first local run (features degrade
# gracefully when unset) but required in production. Never commit real
# values — fill them in a git-ignored .env.local. See docs/CONTINUE-HERE.md.
# ======================================================================

# ---- Auth (NextAuth v5) ----
AUTH_SECRET=""                       # openssl rand -base64 32
AUTH_URL="http://localhost:3000"     # MUST be the exact origin; prod pins https://gigora.ai (see docs/reference-google-oauth)
APP_ORIGIN="http://localhost:3000"   # used for OAuth redirect URIs + same-origin checks
APP_EXTRA_ORIGINS=""                 # optional comma-list of extra allowed origins
GOOGLE_CLIENT_ID=""                  # Google OAuth (lives in the "Gemini API" GCP project)
GOOGLE_CLIENT_SECRET=""

# ---- KYC / PII encryption ----
# base64-encoded 32 bytes: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Prod FAILS CLOSED (500 on phone submit) if unset; dev stores plaintext with a warning.
PII_ENCRYPTION_KEY=""
ADMIN_TELEGRAM_IDS=""                # comma-list of Telegram user ids that are platform admins
TELEGRAM_WEBHOOK_SECRET=""           # shared secret for the Telegram webhook

# ---- AI (search intent + gig wizard) ----
ANTHROPIC_API_KEY=""                 # without it, AI search + gig wizard fall back to deterministic paths
VOYAGE_API_KEY=""                    # semantic (pgvector) search embeddings; optional

# ---- Email (magic-link login, notifications) ----
RESEND_API_KEY=""
EMAIL_FROM="Gigora <noreply@example.com>"

# ---- Private media bucket (order deliverables, requirement files, chat) ----
# When set, those prefixes go to a private R2 bucket served via an access-controlled proxy.
# Unset = they fall back to the public bucket. See src/lib/media.ts.
S3_PRIVATE_BUCKET=""

# ---- Instagram (Business Login auto-sync — needs Meta App Review) ----
# The no-API manual portfolio (paste @handle + post links) works WITHOUT these.
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# ---- Cron (scheduled jobs: reminders, auto-complete, seller-cleanup, etc.) ----
CRON_SECRET=""                       # Bearer secret the cron endpoints require

# ---- Rate limiting ----
# "memory" (default, single-instance) — a distributed backend (redis) is a tracked follow-up.
RATE_LIMIT_BACKEND="memory"

# ---- Observability ----
# Optional generic { text } webhook (Slack/Discord/Telegram) for unexpected 5xx alerts. No-op when unset.
ERROR_ALERT_WEBHOOK=""
# Set to the deploy commit SHA in prod so /api/health reports the running commit (recommended).
APP_VERSION="dev"

# ---- Feature flags / go-live switches ----
# TEST MODE: orders settle for free (no PSP). MUST be removed/0 before taking real money.
FREE_ORDERS="1"
# Set to "payme" or "click" to enable a real PSP checkout (leave empty = manual/free).
PAYMENT_PROVIDER=""

# ---- Analytics + display (all optional, NEXT_PUBLIC_* are exposed to the client) ----
NEXT_PUBLIC_BRAND_NAME="Gigora"
NEXT_PUBLIC_BRAND_DOMAIN="gigora.ai"
NEXT_PUBLIC_CLARITY_ID=""            # Microsoft Clarity
NEXT_PUBLIC_META_PIXEL_ID=""         # Meta Pixel
NEXT_PUBLIC_UZS_PER_USD="12600"      # display-only FX (coarse)
NEXT_PUBLIC_UZS_PER_RUB="135"
